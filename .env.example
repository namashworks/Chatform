# ----------------------------------------------------------------------------
# Required ONLY if you want to run the chatbot from env vars (legacy mode,
# accessible at /?c=env). The generator UI at / asks for the form URL and
# API key in the browser and stores per-tenant configs under tenants/.
# ----------------------------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here

# The Google Form URL the chatbot will fill out (must be a public form).
# Use the "viewform" link, e.g. https://docs.google.com/forms/d/e/1FAIpQLS.../viewform
FORM_URL=https://docs.google.com/forms/d/e/REPLACE_ME/viewform

# Optional: override the default Gemini model
# Recommended: gemini-2.5-flash (fast + good quality).
# Also available: gemini-3.0-flash, gemini-2.0-flash, gemini-2.5-pro (slower).
GEMINI_MODEL=gemini-2.5-flash

# Where this Streamlit app is reachable from a browser. The generator UI
# uses this to build the shareable chatbot URL + HTML embed snippet. When
# deployed behind a real hostname, set it to e.g. https://forms-bot.example.com
PUBLIC_BASE_URL=http://localhost:8501

# TLS / network options ---------------------------------------------------
# Use the Windows certificate store (covers corporate root CAs installed by IT).
# Recommended: leave true on Windows; the app will use truststore.inject_into_ssl().
USE_SYSTEM_CERTS=true

# Verify TLS certs when calling Google. Default true. Set to false ONLY as a
# temporary unblock on networks that do TLS inspection where the corporate
# root CA isn't installed in Windows. Disabling verification is insecure.
SSL_VERIFY=true

# Storage backend ---------------------------------------------------------
# "local" (default) — tenants/ + sessions/ are written to local disk. Use
#                     this for development and any single-machine deployment.
# "cloud"           — tenants live in Firestore, session artifacts in GCS.
#                     Required for Cloud Run / GKE / any multi-instance setup.
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=cloud. Set via the deploy script on Cloud Run.
# GCP_PROJECT=my-gcp-project
# GCS_BUCKET=my-form-chatbot-sessions
# GCS_PREFIX=sessions          # optional, defaults to "sessions"
# FIRESTORE_DATABASE=(default) # optional, defaults to "(default)"
